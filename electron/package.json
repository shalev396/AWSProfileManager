{
  "name": "aws-profile-manager",
  "version": "1.0.0",
  "description": "Desktop app to manage and switch AWS CLI profiles",
  "main": "out/main/index.js",
  "author": "Shalev",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc -b && electron-vite build",
    "typecheck": "tsc -b",
    "lint": "eslint . --max-warnings 0",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "@aws-sdk/client-sso": "^3.1019.0",
    "@aws-sdk/client-sso-oidc": "^3.1019.0",
    "@aws-sdk/client-sts": "^3.1019.0",
    "better-sqlite3": "^12.8.0",
    "ini": "^4.1.1"
  },
  "overrides": {
    "@electron/notarize": "2.3.2",
    "tar": "^7.5.12",
    "rollup": "^4.53.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/ini": "^4.1.1",
    "@types/node": "^24.10.9",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.0.4"
  },
  "build": {
    "appId": "com.shalev.aws-profile-manager",
    "productName": "AWS Profile Manager",
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "afterSign": "notarize.cjs",
    "files": [
      "out",
      "assets/**"
    ],
    "mac": {
      "icon": "assets/icon.png",
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false,
      "extendInfo": {
        "CFBundleName": "AWS Profile Manager",
        "CFBundleDisplayName": "AWS Profile Manager",
        "LSMultipleInstancesProhibit": true
      }
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        "nsis"
      ],
      "signtoolOptions": {
        "publisherName": "Shalev Ben Moshe"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "AWS Profile Manager"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Development",
      "maintainer": "Shalev",
      "synopsis": "Manage and switch AWS CLI profiles"
    }
  }
}
